<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net6.0</TargetFramework>
    <Platforms>x86;x64;AnyCPU;ARM32</Platforms>
	<RuntimeIdentifiers>win-x86;win-x64;linux-x64</RuntimeIdentifiers>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
	<GenerateRuntimeConfigurationFiles>true</GenerateRuntimeConfigurationFiles>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\EwEMSPLink\EwEMSPLink.vbproj" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="MSWSupport\" />
  </ItemGroup>

  <ItemGroup>
    <None Update="Input\**">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      <LinkBase>Input\</LinkBase>
    </None>
  </ItemGroup>
  
</Project>
