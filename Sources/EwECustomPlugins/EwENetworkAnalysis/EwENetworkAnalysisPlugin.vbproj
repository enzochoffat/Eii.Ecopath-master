    <Company>Ecopath International Initiative Research Association</Company>
    <Product>EwENetworkAnalysis plugin</Product>
    <Copyright>Copyright © EII 2007</Copyright>
    <Description>Network Analysis plug-in for Ecopath with Ecosim</Description>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
